/// Non-panicking `let(nonce, ciphertext) = ciphertext.split_at(...)`.
fn try_split_at(slice: &[u8], mid: usize) -> Option<(&[u8], &[u8])> {
 match mid > slice.len() { true => None, false => Some(slice.split_at(mid)) }
}

