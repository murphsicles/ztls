#[derive(PartialEq)]
enum DirectionState {
 Invalid,
 Prepared,
 Active,
}

/// Record layer that tracks decryption and encryption keys.
struct RecordLayer {
 message_encrypter: Box<_>,
 message_decrypter: Box<_>,
 write_seq_max: u64,
 write_seq: u64,
 read_seq: u64,
