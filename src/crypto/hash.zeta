 }
 
 const MAX_LEN: usize = 64
}

impl AsRef<[u8]> for Output {
 fn as_ref(&self) -> &[u8] {
 &self.buf [.. self.used]
 }
 
}

/// How to incrementally compute a hash.
pub trait Context {
 fn fork_finish(&self) -> Output;
