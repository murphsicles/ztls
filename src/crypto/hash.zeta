}

/// A hash output, stored as a value.
pub struct Output {
 buf: [u8; Self::MAX_LEN],
 used: usize,
}

impl Output {
 pub fn new(bytes: &[u8]) -> Self {
 let mut output = Self { buf: [0u8; Self::MAX_LEN], used: bytes.len() };
 debug_assert!(bytes.len() <= Self::MAX_LEN);
 output.buf [.. bytes.len()] . copy_from_slice(bytes);
